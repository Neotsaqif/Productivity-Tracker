# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPTIONAL DATABASE CONFIGURATION:
# If you leave these blank, the app will run with SQLite or Local JSON Backups seamlessly.
# Configure these variables in AI Studio's Settings > Secrets panel to connect to a MySQL server!
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# Alternatively, you can use a unified connection URI:
MYSQL_URL=
DATABASE_URL=

# Resend Email Configuration (for AI Daily Check-In Email System)
RESEND_API_KEY=
EMAIL_FROM="Productivity App <onboarding@resend.dev>"

